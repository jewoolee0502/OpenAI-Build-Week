# The API works without a key by using a deterministic local demo generator.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

HOST=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
DATABASE_URL=postgres://imaginelab:imaginelab_local@localhost:5432/imaginelab
# Tests use a separate database so they never truncate development data.
TEST_DATABASE_URL=postgres://imaginelab:imaginelab_local@localhost:5432/imaginelab_test
AUTO_MIGRATE=true

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8081
