# The API works without a key by using a deterministic local demo generator.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

HOST=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
DATA_FILE=.data/imaginelab.json

# "dev" trusts the X-Demo-User-Id / X-Demo-Role headers for local demos only.
# Production Firebase token verification will replace this mode before deployment.
AUTH_MODE=dev
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
