# The API works without a key by using a deterministic local demo generator.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

HOST=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
DATA_FILE=.data/imaginelab.json

# Local development uses X-Demo-User-Id / X-Demo-Role headers for the demo accounts.
# Production authentication is intentionally not implemented yet.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
