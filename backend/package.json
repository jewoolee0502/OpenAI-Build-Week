{
  "name": "imaginelab-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "db:up": "docker compose -f ../compose.yaml up -d postgres",
    "db:down": "docker compose -f ../compose.yaml down",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "demo:polish": "tsx scripts/polish-local-demo.mjs",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "11.3.0",
    "@fastify/multipart": "^10.1.0",
    "argon2": "^0.45.0",
    "dotenv": "17.4.2",
    "fastify": "5.10.0",
    "openai": "6.48.0",
    "pg": "^8.22.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "^8.20.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
