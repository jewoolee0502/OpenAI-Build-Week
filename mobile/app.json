{
  "expo": {
    "name": "ImagineLab",
    "slug": "imaginelab",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "imaginelab",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.imaginelab.app"
    },
    "android": {
      "package": "com.imaginelab.app",
      "adaptiveIcon": {
        "backgroundColor": "#17142B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#17142B",
          "dark": {
            "backgroundColor": "#17142B"
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Let ImagineLab hear your game idea while you hold the talk button.",
          "recordAudioAndroid": true,
          "enableBackgroundRecording": false
        }
      ],
      "expo-asset",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
