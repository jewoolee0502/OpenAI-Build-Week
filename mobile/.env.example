# Android Emulator default: http://10.0.2.2:8080
# iOS Simulator / web default: http://localhost:8080
# A physical phone must use your computer's LAN address, for example:
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8080
# Browser development on the same Mac uses localhost by default. Set this only when the web
# client needs a different backend address.
EXPO_PUBLIC_WEB_API_BASE_URL=http://localhost:8080
